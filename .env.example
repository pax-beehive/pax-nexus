# OpenCode consumer and producer model.
OPENCODE_MODEL=deepseek/deepseek-v4-flash
OPENCODE_VERSION=1.17.20
DEEPSEEK_API_KEY=replace-me

# Single-Team on-prem authentication. Agent credentials are enrolled through
# the admin HTTP API and always resolve to the internal local-team scope.
TEAM_MEMORY_ADMIN_API_KEY=replace-with-a-secret-admin-key
TEAM_MEMORY_CREDENTIAL_ROTATION_OVERLAP=5m
TEAM_MEMORY_WIKI_HINT_ENABLED=false
TEAM_MEMORY_OPERATIONS_EVENT_RETENTION=168h
TEAM_MEMORY_OPERATIONS_STORAGE_RETENTION=2160h
TEAM_MEMORY_OPERATIONS_SNAPSHOT_INTERVAL=1h
TEAM_MEMORY_OPERATIONS_MAINTENANCE_TIMEOUT=15s

# Team Note extraction through the OpenAI-compatible DeepSeek API.
TEAM_MEMORY_EXTRACTOR_BASE_URL=https://api.deepseek.com
TEAM_MEMORY_EXTRACTOR_API_KEY=replace-me
TEAM_MEMORY_EXTRACTOR_MODEL=deepseek-v4-flash
TEAM_MEMORY_PROMPT_VERSION=v2-rolling
TEAM_MEMORY_EXTRACTION_CONTEXT_MODE=rolling
# Extraction v1 is the production default; set v1.1 or v2 only for an explicit experiment.
TEAM_MEMORY_EXTRACTION_VERSION=v1
# Candidate strategies apply only to extraction v2. Leave empty to use the
# build default, source-clause-v1. Registered strategies are current, interaction-slim,
# evidence-fidelity-v1, source-clause-v1, source-clause-implicit-state-v1, typed-2, source-span-v1,
# source-span-v2, claim-card-v1, or claim-card-v2. Evidence Fidelity, Source
# Span, Implicit State, and Claim Card candidates remain available only for reproducibility.
TEAM_MEMORY_EXTRACTION_CANDIDATE_STRATEGY=
TEAM_MEMORY_EXTRACTION_PROVIDER_TIMEOUT=120s
TEAM_MEMORY_EXTRACTION_PROVIDER_MAX_ATTEMPTS=1
TEAM_MEMORY_EXTRACTION_PROVIDER_RETRY_BACKOFF=250ms
TEAM_MEMORY_EXTRACTION_PROVIDER_MAX_RESPONSE_BYTES=1048576
TEAM_MEMORY_EXTRACTION_PRIMARY_MAX_OUTPUT_TOKENS=16384
TEAM_MEMORY_EXTRACTION_SUMMARY_MAX_OUTPUT_TOKENS=4096
TEAM_MEMORY_EXTRACTION_COMPACTION_MAX_OUTPUT_TOKENS=4096
TEAM_MEMORY_WORKER_JOB_TIMEOUT=3m
TEAM_MEMORY_MAX_SLICES_PER_JOB=1
# Recall policy is selected at build time. passive-v1 is the production
# default; hint-v1-selective preserves passive recall and adds one focused
# active recall when its selectivity gates pass.
TEAM_MEMORY_BUILD_RECALL_CANDIDATE_STRATEGY=passive-v1
TEAM_MEMORY_EXTRACTION_COMPACTION_ENABLED=false
TEAM_MEMORY_EXTRACTION_SUMMARY_ENABLED=true
TEAM_MEMORY_EXTRACTION_SUMMARY_TRIGGER_TOKENS=8192
TEAM_MEMORY_EXTRACTION_SUMMARY_TAIL_TOKENS=16384
TEAM_MEMORY_EXTRACTION_COMPACT_START_TOKENS=12288
TEAM_MEMORY_EXTRACTION_COMPACT_TOKENS=16384

# Self-hosted Mem0 uses DeepSeek for extraction and keeps OpenAI embeddings.
MEM0_OPENAI_API_KEY=replace-me
MEM0_DEFAULT_LLM_MODEL=deepseek-v4-flash
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small
MEM0_IMAGE=mem0/mem0-api-server:latest

# paxm source used as the OpenCode Docker build context.
PAXM_SOURCE_DIR=/absolute/path/to/memory-adaptor

# Eval v2 durable run store exposed by evals/v2/compose.yaml.
EVAL_V2_POSTGRES_DSN=postgres://team_memory:team_memory@127.0.0.1:55433/team_memory?sslmode=disable
