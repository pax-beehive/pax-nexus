# OpenCode consumer and producer model.
OPENCODE_MODEL=deepseek/deepseek-v4-flash
OPENCODE_VERSION=1.17.20
DEEPSEEK_API_KEY=replace-me

# Team Note extraction through the OpenAI-compatible DeepSeek API.
TEAM_MEMORY_EXTRACTOR_BASE_URL=https://api.deepseek.com
TEAM_MEMORY_EXTRACTOR_API_KEY=replace-me
TEAM_MEMORY_EXTRACTOR_MODEL=deepseek-v4-flash
TEAM_MEMORY_PROMPT_VERSION=v1

# Self-hosted Mem0 uses DeepSeek for extraction and keeps OpenAI embeddings.
MEM0_OPENAI_API_KEY=replace-me
MEM0_DEFAULT_LLM_MODEL=deepseek-v4-flash
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small
MEM0_IMAGE=mem0/mem0-api-server:latest

# paxm source used as the OpenCode Docker build context.
PAXM_SOURCE_DIR=/absolute/path/to/memory-adaptor

# Eval v2 durable run store exposed by evals/v2/compose.yaml.
EVAL_V2_POSTGRES_DSN=postgres://team_memory:team_memory@127.0.0.1:55433/team_memory?sslmode=disable
