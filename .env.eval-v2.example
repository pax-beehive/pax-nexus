# Eval v2 overrides. Copy this file to .env.eval-v2 and keep secrets local.

# OpenCode and Team Note inherit DEEPSEEK_API_KEY and extractor credentials
# from .env. These values pin the non-secret runtime configuration recorded in
# artifacts.json.
OPENCODE_MODEL=deepseek/deepseek-v4-flash
OPENCODE_VERSION=1.17.20
TEAM_MEMORY_EXTRACTOR_BASE_URL=https://api.deepseek.com
TEAM_MEMORY_EXTRACTOR_MODEL=deepseek-v4-flash
TEAM_MEMORY_PROMPT_VERSION=v1

# Self-hosted Mem0 uses DeepSeek V4 Flash for memory extraction and OpenAI embeddings.
MEM0_OPENAI_API_KEY=replace-me
MEM0_DEFAULT_LLM_MODEL=deepseek-v4-flash
MEM0_DEEPSEEK_BASE_URL=https://api.deepseek.com
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small
MEM0_IMAGE=mem0/mem0-api-server@sha256:2fcf4bb713cfc584d454bf06993cc7e2fe51540695995bd3aa9c7008b7065c75
MEM0_POSTGRES_PASSWORD=mem0-eval-local-only
MEM0_JWT_SECRET=replace-with-a-local-random-secret

# Publishable benchmarks use provider-local rank/top-k by default. Override
# these only with provider-calibrated thresholds and record the values.
PAXM_PASSIVE_MIN_RELEVANCE=-1
PAXM_PASSIVE_MIN_SCORE=-1
PAXM_INSERTION_MIN_SCORE=0
PAXM_EVAL_DIAGNOSTICS=1

# Eval v2 PostgreSQL is exposed by evals/v2/compose.yaml.
EVAL_V2_POSTGRES_PORT=55433
EVAL_V2_POSTGRES_DSN=postgres://team_memory:team_memory@127.0.0.1:55433/team_memory?sslmode=disable

# Runner inputs used by the Make targets.
EVAL_V2_CONFIG=evals/v2/config.local.yaml
EVAL_V2_MANIFEST=runs/groupmembench-v2-selection/manifest.json
EVAL_V2_RUN_ID=groupmembench-finance-v2-deepseek-v4-flash
